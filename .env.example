# --- Time-Off Microservice configuration ---

# HTTP port the microservice listens on
PORT=3000

# SQLite database file. Use ":memory:" for an ephemeral in-memory DB.
DATABASE_PATH=./data/time-off.sqlite

# Base URL of the HCM system (the mock HCM server, or a real Workday/SAP gateway)
HCM_BASE_URL=http://localhost:4000

# HCM HTTP client tuning
HCM_TIMEOUT_MS=5000
HCM_MAX_RETRIES=5

# Background job cadence (cron expressions / intervals)
# Outbox processor interval in milliseconds
OUTBOX_POLL_INTERVAL_MS=2000
# Reconciliation pull cron (default: every 5 minutes)
RECONCILE_CRON=*/5 * * * *

# Set to "true" to disable all background schedulers (useful for deterministic tests)
DISABLE_SCHEDULERS=false
